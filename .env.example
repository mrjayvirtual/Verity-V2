# ============================================================
#  Verity V2 — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Google AI Studio API Key
# Get one at: https://aistudio.google.com/app/apikey
#
# IMPORTANT: The variable name is Google_Api_key (mixed case).
# The server reads process.env.Google_Api_key — match exactly.
# ----------------------------------------------------------
Google_Api_key=your_google_ai_studio_api_key_here

# ----------------------------------------------------------
# Express Session Secret
# Any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------
SESSION_SECRET=replace_with_a_long_random_string

# ----------------------------------------------------------
# PostgreSQL Connection String
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Examples:
#   Local:   postgresql://postgres:password@localhost:5432/verity
#   Neon:    postgresql://user:pass@ep-xxx.neon.tech/verity?sslmode=require
#   Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
# ----------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/verity
